            section="Triệu chứng",
            subsection=None,
            chunk_index=1,
            text="Bệnh vảy nến có thể gây mảng đỏ, bong vảy trắng bạc và ngứa.",
            contextualized_text=(
                "Bài viết: Bệnh vảy nến\n"
                "Mục: Triệu chứng\n\n"
                "Bệnh vảy nến có thể gây mảng đỏ, bong vảy trắng bạc và ngứa."
            ),
