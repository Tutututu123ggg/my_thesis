# =========================
# App
# =========================
APP_NAME=medical-vietnamese-hybrid-rag
APP_ENV=development
LOG_LEVEL=INFO

# =========================
# Neo4j
# =========================
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=admin123456 #example
NEO4J_DATABASE=neo4j

# =========================
# OpenAI / LLM
# =========================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# =========================
# Local LLM / Ollama
# =========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# =========================
# Embedding
# =========================
EMBEDDING_MODEL=BAAI/bge-m3

# =========================
# Redis / Celery
# =========================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =========================
# Paths
# =========================
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CHUNK_DATA_DIR=data/chunks
EXTRACTION_DATA_DIR=data/extraction
GRAPH_EXPORT_DIR=data/graph_exports
VECTOR_STORE_DIR=data/vector_store
EVALUATION_DIR=data/evaluation
LOG_DIR=data/logs

# =========================
# Qdrant
# =========================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_CHUNK_COLLECTION=medical_chunks
QDRANT_ENTITY_COLLECTION=medical_entities
QDRANT_RELATION_COLLECTION=medical_relations
VECTOR_DIM=768
VECTOR_DISTANCE=cosine